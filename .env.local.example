# ============================================================
# MN FERMETURES — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez vos valeurs.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Récupérez ces valeurs dans : Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── URL du site (production) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mn-fermetures-front.vercel.app

# ── Stripe (Sprint 3 — paiement CB) ──────────────────────────
# Récupérez ces valeurs dans : Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Email transactionnel (ex. Resend, SendGrid) ──────────────
RESEND_API_KEY=re_...
EMAIL_FROM=commandes@mnfermetures.fr
