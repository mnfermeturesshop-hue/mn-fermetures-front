# ============================================================
# MN FERMETURES — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez vos valeurs.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Récupérez ces valeurs dans : Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role — uniquement côté serveur (routes API admin). Ne jamais mettre en NEXT_PUBLIC_
# Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── URL du site (production) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mn-fermetures-front.vercel.app

# ── Stripe (Sprint 3 — paiement CB) ──────────────────────────
# Récupérez ces valeurs dans : Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Email transactionnel — Gmail SMTP ────────────────────────
# Votre adresse Gmail
GMAIL_USER=votre.adresse@gmail.com
# Mot de passe d'application (PAS votre vrai mot de passe)
# Google Account → Sécurité → Validation en 2 étapes → Mots de passe des applications
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Cloudflare Turnstile (protection anti-bots) ───────────────
# Cloudflare Dashboard → Turnstile → Votre site → Site Key + Secret Key
# Clés de test (bypass automatique) :
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
